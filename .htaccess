# Ryou Accounting AIO — pastikan file PWA disajikan dengan tipe & header yang benar.
# Kalau manifest.json / service-worker.js kebaca dengan Content-Type yang salah,
# browser akan menolak menawarkan "Install app" dan cuma kasih opsi "Add shortcut".

<IfModule mod_mime.c>
  AddType application/manifest+json .json
  AddType application/javascript .js
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "manifest\.json$">
    Header set Content-Type "application/manifest+json"
    Header set Cache-Control "no-cache"
  </FilesMatch>
  <FilesMatch "service-worker\.js$">
    Header set Content-Type "application/javascript"
    Header set Service-Worker-Allowed "/"
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
